#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
╔══════════════════════════════════════════════════════════════╗
║       Serverraum-Überwachung – Hauptscript                   ║
║       Alle UIDs aus Projektdokumentation eingetragen         ║
╚══════════════════════════════════════════════════════════════╝

Sensoren:
  - PTC Bricklet 2.0           (Wcg)  → Temperatur
  - Ambient Light Bricklet 3.0 (Pdw)  → Helligkeit / Tür offen
  - Humidity Bricklet 2.0      (ViW)  → Luftfeuchtigkeit
  - Motion Detector Bricklet 2.0(ML4) → Bewegung
  - NFC Bricklet               (22ND) → System aktivieren/quittieren
  - Dual Button Bricklet 2.0   (Vd8)  → Alarm quittieren/zurücksetzen

Aktoren:
  - RGB LED Button Bricklet    (23Qx) → Zustandsanzeige
  - Piezo Speaker Bricklet 2.0 (R7M)  → Alarm / Warnung
  - E-Paper 296x128            (24KJ) → Statusanzeige
  - Segment Display 4x7 V2     (Tre)  → Zeitdauer krit. Zustand
  - LCD 128x64                 (24Rh) → Live-Werte / Touch

Voraussetzung: pip install tinkerforge
"""

import time
import threading
from tinkerforge.ip_connection import IPConnection
from tinkerforge.bricklet_ptc_v2 import BrickletPtcV2
from tinkerforge.bricklet_ambient_light_v3 import BrickletAmbientLightV3
from tinkerforge.bricklet_humidity_v2 import BrickletHumidityV2
from tinkerforge.bricklet_motion_detector_v2 import BrickletMotionDetectorV2
from tinkerforge.bricklet_nfc import BrickletNFC
from tinkerforge.bricklet_dual_button_v2 import BrickletDualButtonV2
from tinkerforge.bricklet_rgb_led_button import BrickletRGBLEDButton
from tinkerforge.bricklet_piezo_speaker_v2 import BrickletPiezoSpeakerV2
from tinkerforge.bricklet_e_paper_296x128 import BrickletEPaper296x128
from tinkerforge.bricklet_segment_display_4x7_v2 import BrickletSegmentDisplay4x7V2
from tinkerforge.bricklet_lcd_128x64 import BrickletLCD128x64

# ══════════════════════════════════════════════════════════════════════════════
# KONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
HOST = "192.168.1.100"   # <-- IP des Master Bricks anpassen

PORT = 4223

# UIDs (aus Projektdokumentation)
UID_PTC      = "Wcg"
UID_LIGHT    = "Pdw"
UID_HUMIDITY = "ViW"
UID_MOTION   = "ML4"
UID_NFC      = "22ND"
UID_DUALBT   = "Vd8"
UID_RGBLED   = "23Qx"
UID_PIEZO    = "R7M"
UID_EPAPER   = "24KJ"
UID_SEGMENT  = "Tre"
UID_LCD      = "24Rh"

# ── Schwellwerte ───────────────────────────────────────────────────────────────
TEMP_WARN    = 26.0   # °C  – Warnung ab
TEMP_CRIT    = 32.0   # °C  – Kritisch ab
TEMP_LOW     = 15.0   # °C  – Zu kalt (Warnung)

HUMID_WARN   = 60.0   # %RH – Warnung ab
HUMID_CRIT   = 75.0   # %RH – Kritisch ab (Kondensationsgefahr)
HUMID_LOW    = 20.0   # %RH – Zu trocken (statische Aufladung)

LIGHT_DOOR_OPEN = 50.0  # lx  – ab diesem Wert gilt Tür als offen

POLL_INTERVAL = 2.0   # Sekunden zwischen Sensor-Abfragen


# ══════════════════════════════════════════════════════════════════════════════
# SYSTEMZUSTAND
# ══════════════════════════════════════════════════════════════════════════════
state = {
    "aktiv":           True,    # System aktiv (NFC toggle)
    "alarm":           False,   # Aktiver Alarm
    "alarm_quittiert": False,   # Alarm quittiert (Piezo stumm)
    "zustand":         "OK",    # "OK" / "WARNUNG" / "KRITISCH"
    "krit_seit":       None,    # Zeitstempel Beginn krit. Zustand
    "krit_dauer_s":    0,       # Sekunden im krit. Zustand
    "temp":            0.0,
    "humidity":        0.0,
    "lux":             0.0,
    "motion":          False,
    "tuer_offen":      False,
}

lock = threading.Lock()


# ══════════════════════════════════════════════════════════════════════════════
# HILFSFUNKTIONEN
# ══════════════════════════════════════════════════════════════════════════════
def zustand_berechnen(temp, humidity):
    """Ermittelt Gesamtzustand basierend auf Temp + Feuchtigkeit."""
    if temp >= TEMP_CRIT or temp <= TEMP_LOW or humidity >= HUMID_CRIT:
        return "KRITISCH"
    elif temp >= TEMP_WARN or humidity >= HUMID_WARN or humidity <= HUMID_LOW:
        return "WARNUNG"
    return "OK"


def rgb_fuer_zustand(zustand):
    """Gibt RGB-Werte für Zustand zurück."""
    return {
        "OK":       (0, 255, 0),    # Grün
        "WARNUNG":  (255, 165, 0),  # Orange
        "KRITISCH": (255, 0, 0),    # Rot
    }.get(zustand, (0, 0, 255))


# ══════════════════════════════════════════════════════════════════════════════
# CALLBACKS
# ══════════════════════════════════════════════════════════════════════════════
def cb_motion_detected():
    with lock:
        state["motion"] = True
    print("  [Motion] Bewegung erkannt!")

def cb_motion_ended():
    with lock:
        state["motion"] = False
    print("  [Motion] Keine Bewegung mehr.")

def cb_button_state_changed(button_l, button_r, led_l, led_r):
    """Linker Button = Alarm quittieren | Rechter Button = Reset"""
    if button_l == BrickletDualButtonV2.BUTTON_STATE_PRESSED:
        with lock:
            state["alarm_quittiert"] = True
        print("  [DualButton] Alarm quittiert (linker Button).")

    if button_r == BrickletDualButtonV2.BUTTON_STATE_PRESSED:
        with lock:
            state["alarm"]           = False
            state["alarm_quittiert"] = False
            state["zustand"]         = "OK"
            state["krit_seit"]       = None
            state["krit_dauer_s"]    = 0
        print("  [DualButton] System zurückgesetzt (rechter Button).")

def cb_nfc_reader_state_changed(reader_state, idle):
    """NFC-Tag erkannt → System aktivieren/deaktivieren."""
    if reader_state == BrickletNFC.READER_STATE_REQUEST_TAG_ID_READY:
        with lock:
            state["aktiv"] = not state["aktiv"]
        status = "AKTIVIERT" if state["aktiv"] else "DEAKTIVIERT"
        print(f"  [NFC] Tag erkannt → System {status}")


# ══════════════════════════════════════════════════════════════════════════════
# AKTOREN UPDATEN
# ══════════════════════════════════════════════════════════════════════════════
def update_rgb(rgb_btn, zustand):
    r, g, b = rgb_fuer_zustand(zustand)
    rgb_btn.set_color(r, g, b)


def update_piezo(piezo, zustand, quittiert):
    """Piezo: Kritisch = Alarm-Sweep | Warnung = kurzer Beep | OK = aus."""
    if quittiert or zustand == "OK":
        piezo.set_beep(frequency=1000, volume=2,
                       duration=BrickletPiezoSpeakerV2.BEEP_DURATION_OFF)
    elif zustand == "KRITISCH":
        piezo.set_alarm(
            start_frequency=800,
            end_frequency=2400,
            step_size=200,
            step_delay=30,
            volume=2,
            duration=BrickletPiezoSpeakerV2.ALARM_DURATION_INFINITE
        )
    elif zustand == "WARNUNG":
        piezo.set_beep(frequency=1200, volume=2, duration=300)


def update_segment(seg, krit_dauer_s):
    """Zeigt Sekunden im kritischen Zustand auf 4 Stellen an (max 9999s)."""
    sek = min(int(krit_dauer_s), 9999)
    d0 = sek // 1000
    d1 = (sek % 1000) // 100
    d2 = (sek % 100) // 10
    d3 = sek % 10
    seg.set_numeric_value([d0, d1, d2, d3])


def update_lcd(lcd, s):
    """Schreibt aktuelle Werte auf LCD 128x64."""
    lcd.clear_display()
    lcd.write_line(0, 0, f"Temp:  {s['temp']:5.1f} C")
    lcd.write_line(1, 0, f"Feuch: {s['humidity']:5.1f} %RH")
    lcd.write_line(2, 0, f"Licht: {s['lux']:6.1f} lx")
    lcd.write_line(3, 0, f"Tuer:  {'OFFEN' if s['tuer_offen'] else 'ZU   '}")
    lcd.write_line(4, 0, f"Motion:{'JA' if s['motion'] else 'NEIN'}")
    lcd.write_line(5, 0, f"Status:{s['zustand']}")
    lcd.write_line(6, 0, f"KritSek: {s['krit_dauer_s']:4d}s")
    lcd.write_line(7, 0, time.strftime("%d.%m.%Y %H:%M:%S"))


def update_epaper(ep, s):
    """E-Paper nur bei Zustandswechsel neu zeichnen (langsam ~7.5s)."""
    ep.fill_display(BrickletEPaper296x128.COLOR_WHITE)

    # Titelzeile
    ep.draw_text(5, 5, BrickletEPaper296x128.FONT_12X16,
                 BrickletEPaper296x128.COLOR_BLACK,
                 BrickletEPaper296x128.ORIENTATION_HORIZONTAL,
                 "Serverraum-Monitoring")

    # Statuszeile (rot bei Kritisch/Warnung)
    farbe = (BrickletEPaper296x128.COLOR_RED
             if s["zustand"] != "OK"
             else BrickletEPaper296x128.COLOR_BLACK)
    ep.draw_text(5, 28, BrickletEPaper296x128.FONT_18X32,
                 farbe,
                 BrickletEPaper296x128.ORIENTATION_HORIZONTAL,
                 s["zustand"])

    # Sensorwerte
    ep.draw_text(5, 68, BrickletEPaper296x128.FONT_12X16,
                 BrickletEPaper296x128.COLOR_BLACK,
                 BrickletEPaper296x128.ORIENTATION_HORIZONTAL,
                 f"T:{s['temp']:.1f}C  H:{s['humidity']:.1f}%")

    ep.draw_text(5, 88, BrickletEPaper296x128.FONT_6X8,
                 BrickletEPaper296x128.COLOR_BLACK,
                 BrickletEPaper296x128.ORIENTATION_HORIZONTAL,
                 f"Tuer: {'OFFEN' if s['tuer_offen'] else 'ZU'}  "
                 f"Motion: {'JA' if s['motion'] else 'NEIN'}")

    ep.draw_text(5, 108, BrickletEPaper296x128.FONT_6X8,
                 BrickletEPaper296x128.COLOR_BLACK,
                 BrickletEPaper296x128.ORIENTATION_HORIZONTAL,
                 time.strftime("%d.%m.%Y  %H:%M:%S"))

    ep.draw()


# ══════════════════════════════════════════════════════════════════════════════
# HAUPTSCHLEIFE
# ══════════════════════════════════════════════════════════════════════════════
def main():
    ipcon = IPConnection()

    # Bricklets initialisieren
    ptc      = BrickletPtcV2(UID_PTC, ipcon)
    light    = BrickletAmbientLightV3(UID_LIGHT, ipcon)
    humidity = BrickletHumidityV2(UID_HUMIDITY, ipcon)
    motion   = BrickletMotionDetectorV2(UID_MOTION, ipcon)
    nfc      = BrickletNFC(UID_NFC, ipcon)
    dualbt   = BrickletDualButtonV2(UID_DUALBT, ipcon)
    rgb_btn  = BrickletRGBLEDButton(UID_RGBLED, ipcon)
    piezo    = BrickletPiezoSpeakerV2(UID_PIEZO, ipcon)
    epaper   = BrickletEPaper296x128(UID_EPAPER, ipcon)
    segment  = BrickletSegmentDisplay4x7V2(UID_SEGMENT, ipcon)
    lcd      = BrickletLCD128x64(UID_LCD, ipcon)

    ipcon.connect(HOST, PORT)
    print(f"Verbunden mit {HOST}:{PORT}\n")
    print("╔══════════════════════════════════╗")
    print("║  Serverraum-Monitoring gestartet ║")
    print("╚══════════════════════════════════╝\n")
    print(f"  Schwellwerte:")
    print(f"    Temp:  Warnung ≥ {TEMP_WARN}°C  |  Kritisch ≥ {TEMP_CRIT}°C")
    print(f"    Feuch: Warnung ≥ {HUMID_WARN}%  |  Kritisch ≥ {HUMID_CRIT}%")
    print(f"    Tür:   Offen ab ≥ {LIGHT_DOOR_OPEN} lx\n")

    # Callbacks registrieren
    motion.register_callback(
        BrickletMotionDetectorV2.CALLBACK_MOTION_DETECTED, cb_motion_detected)
    motion.register_callback(
        BrickletMotionDetectorV2.CALLBACK_DETECTION_CYCLE_ENDED, cb_motion_ended)
    motion.set_sensitivity(85)

    dualbt.register_callback(
        BrickletDualButtonV2.CALLBACK_STATE_CHANGED, cb_button_state_changed)

    nfc.set_mode(BrickletNFC.MODE_READER)
    nfc.register_callback(
        BrickletNFC.CALLBACK_READER_STATE_CHANGED, cb_nfc_reader_state_changed)

    # LCD Hintergrundbeleuchtung
    lcd.set_display_configuration(14, 100, False, True)

    letzter_zustand = None
    letzter_epaper_update = 0

    try:
        while True:
            if not state["aktiv"]:
                rgb_btn.set_color(0, 0, 50)   # Blau = System inaktiv
                piezo.set_beep(frequency=1000, volume=2,
                               duration=BrickletPiezoSpeakerV2.BEEP_DURATION_OFF)
                time.sleep(POLL_INTERVAL)
                continue

            # ── Sensoren lesen ────────────────────────────────────────────────
            temp     = ptc.get_temperature() / 100.0
            lux      = light.get_illuminance() / 100.0
            hum      = humidity.get_humidity() / 100.0
            tuer     = lux >= LIGHT_DOOR_OPEN

            with lock:
                state["temp"]       = temp
                state["lux"]        = lux
                state["humidity"]   = hum
                state["tuer_offen"] = tuer

            # ── Zustand berechnen ─────────────────────────────────────────────
            neuer_zustand = zustand_berechnen(temp, hum)

            with lock:
                if neuer_zustand == "KRITISCH":
                    if state["krit_seit"] is None:
                        state["krit_seit"] = time.time()
                    state["krit_dauer_s"] = int(time.time() - state["krit_seit"])
                    state["alarm"] = True
                else:
                    state["krit_seit"]    = None
                    state["krit_dauer_s"] = 0
                    if neuer_zustand == "OK":
                        state["alarm"] = False
                        state["alarm_quittiert"] = False

                state["zustand"] = neuer_zustand
                snap = dict(state)   # Snapshot für Aktoren

            # ── Konsole ───────────────────────────────────────────────────────
            print(f"[{time.strftime('%H:%M:%S')}] "
                  f"Temp: {temp:.1f}°C  "
                  f"Feuch: {hum:.1f}%  "
                  f"Licht: {lux:.0f}lx  "
                  f"Tür: {'OFFEN' if tuer else 'ZU':5s}  "
                  f"→ {neuer_zustand}"
                  + (f"  [{snap['krit_dauer_s']}s]" if neuer_zustand == "KRITISCH" else ""))

            # ── Aktoren updaten ───────────────────────────────────────────────
            update_rgb(rgb_btn, neuer_zustand)
            update_piezo(piezo, neuer_zustand, snap["alarm_quittiert"])
            update_segment(segment, snap["krit_dauer_s"])
            update_lcd(lcd, snap)

            # E-Paper: nur bei Zustandswechsel oder alle 60s neu zeichnen
            jetzt = time.time()
            if (neuer_zustand != letzter_zustand
                    or jetzt - letzter_epaper_update > 60):
                print("  [E-Paper] Update ...")
                update_epaper(epaper, snap)
                letzter_zustand      = neuer_zustand
                letzter_epaper_update = jetzt

            # Dual-Button LEDs: Links = Alarm aktiv | Rechts = System OK
            led_l = (BrickletDualButtonV2.LED_STATE_ON
                     if snap["alarm"] and not snap["alarm_quittiert"]
                     else BrickletDualButtonV2.LED_STATE_OFF)
            led_r = (BrickletDualButtonV2.LED_STATE_ON
                     if neuer_zustand == "OK"
                     else BrickletDualButtonV2.LED_STATE_OFF)
            dualbt.set_led_state(led_l, led_r)

            time.sleep(POLL_INTERVAL)

    except KeyboardInterrupt:
        print("\n\nSystem gestoppt (Strg+C).")
    finally:
        # Alles ausschalten beim Beenden
        rgb_btn.set_color(0, 0, 0)
        piezo.set_beep(frequency=1000, volume=2,
                       duration=BrickletPiezoSpeakerV2.BEEP_DURATION_OFF)
        segment.set_numeric_value([-1, -1, -1, -1])
        lcd.clear_display()
        lcd.write_line(0, 0, "  System offline")
        ipcon.disconnect()
        print("Verbindung getrennt.")


if __name__ == "__main__":
    main()
